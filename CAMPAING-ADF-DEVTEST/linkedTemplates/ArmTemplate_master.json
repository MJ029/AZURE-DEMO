{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "CAMPAING-ADF-DEVTEST"
		},
		"LS_ABS_properties_typeProperties_connectionString_secretName": {
			"type": "string",
			"defaultValue": "@linkedService().LS_PRM_BLOB_CONN_STRNG_SCRT_NAME"
		},
		"LS_ADLS_GEN2_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://campaignadlsgen2devtest.dfs.core.windows.net"
		},
		"LS_ADLS_GEN2_properties_typeProperties_tenant": {
			"type": "string",
			"defaultValue": "44bb2b85-300c-44d0-b08a-658ac3914f86"
		},
		"LS_ADLS_GEN2_properties_typeProperties_servicePrincipalId": {
			"type": "string",
			"defaultValue": "@{linkedService().APP_ID}"
		},
		"LS_AKV_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "@{linkedService().PRM_AKV}"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "CAMPAING-ADF-DEVTEST_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2018-02-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_AKV_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_AKV_properties_typeProperties_baseUrl')]"
					},
					"LS_ABS_properties_typeProperties_connectionString_secretName": {
						"value": "[parameters('LS_ABS_properties_typeProperties_connectionString_secretName')]"
					},
					"LS_ADLS_GEN2_properties_typeProperties_url": {
						"value": "[parameters('LS_ADLS_GEN2_properties_typeProperties_url')]"
					},
					"LS_ADLS_GEN2_properties_typeProperties_tenant": {
						"value": "[parameters('LS_ADLS_GEN2_properties_typeProperties_tenant')]"
					},
					"LS_ADLS_GEN2_properties_typeProperties_servicePrincipalId": {
						"value": "[parameters('LS_ADLS_GEN2_properties_typeProperties_servicePrincipalId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}